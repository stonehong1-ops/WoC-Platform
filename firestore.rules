rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /venues/{venueId} {
      allow read: if true;
      allow write: if true;
    }
    match /plaza/{postId} {
      allow read: if true;
      allow write: if true;
      match /comments/{commentId} {
        allow read: if true;
        allow write: if true;
      }
    }
    match /chat_rooms/{roomId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /chat_messages/{messageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /classes/{classId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /shops/{shopId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /stay/{stayId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /services/{serviceId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /resale/{resaleId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /lost/{lostId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /arcade/{arcadeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /socials/{socialId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /galleries/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /gallery_comments/{commentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /spaces/{spaceId} {
      allow read: if true;
      // You can tighten this later (e.g. only owner can write). For now logged in users.
      allow write: if request.auth != null;
    }
    match /communities/{communityId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /posts/{postId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
  }
}
