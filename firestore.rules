rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.uid == userId || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
      );
    }
    match /venues/{venueId} {
      allow read: if true;
      allow write: if true;
    }
    match /plaza/{postId} {
      allow read: if true;
      allow write: if true;
      match /comments/{commentId} {
        allow read: if true;
        allow write: if true;
      }
    }
    match /chat_rooms/{roomId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /chat_messages/{messageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /events/{eventId} {
      allow read: if true;
      allow write: if true;
    }
    match /classes/{classId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /shops/{shopId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /stay/{stayId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /stays/{stayId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /stay_bookings/{bookingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /services/{serviceId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /resale/{resaleId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /resale_items/{itemId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /resale_likes/{likeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /user_reputation/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /lost/{lostId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /arcade/{arcadeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /socials/{socialId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /galleries/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /gallery_comments/{commentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /groups/{groupId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /posts/{postId} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      match /members/{memberId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
      match /classes/{classId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
      match /monthlyPasses/{passId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
      match /discounts/{discountId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    match /feeds/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
      match /comments/{commentId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
      match /reactions/{reactionId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    match /class_registrations/{registrationId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /rental_spaces/{spaceId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /rental_likes/{likeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /rental_requests/{requestId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /shop_orders/{orderId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /product_likes/{likeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /shop_banners/{bannerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /cartoons/{cartoonId} {
      allow read: if true;
      allow write: if true;
      
      match /reviews/{reviewId} {
        allow read: if true;
        allow write: if true;
      }
    }

    match /lost_found_items/{itemId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }
    match /lost_found_likes/{likeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

  }
}
