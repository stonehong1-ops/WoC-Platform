rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /venues/{venueId} {
      allow read: if true;
      allow write: if true;
    }
    match /plaza/{postId} {
      allow read: if true;
      allow write: if true;
      match /comments/{commentId} {
        allow read: if true;
        allow write: if true;
      }
    }
    match /chat_rooms/{roomId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /chat_messages/{messageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /socials/{eventId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
