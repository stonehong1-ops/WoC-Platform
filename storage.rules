rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /profiles/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /plaza/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /venues/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /chat/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /gallery/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /feeds/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /posts/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /socials/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /groups/{groupId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
