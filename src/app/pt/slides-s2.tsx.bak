// Slide 8: Money Flows Here
import { BookOpen, Drama, Bike, Home, Plane } from 'lucide-react';

const categories = [
  { icon: <BookOpen size={16} />, label: 'Class' },
  { icon: <Drama size={16} />, label: 'Performance' },
  { icon: <Bike size={16} />, label: 'Gear' },
  { icon: <Home size={16} />, label: 'Fandom' },
  { icon: <Plane size={16} />, label: 'Travel' },
];

export const Slide8 = () => {
  // Donut chart calculations (r=80, C=502.6)
  // Segments: Red (66.7%), Blue (23.3%), Light Red (10%)
  const c = 502.6;
  const redDash = (66.7 / 100) * c;
  const blueDash = (23.3 / 100) * c;
  const lightRedDash = (10 / 100) * c;

  return (
    <div className="relative z-10 flex w-full h-full p-[60px] md:p-[80px] bg-[#fcfcfc] text-left overflow-hidden rounded-2xl shadow-sm">
      {/* Left Section (40%) */}
      <div className="w-[40%] flex flex-col pt-10">
        <h1 className="text-[70px] md:text-[90px] font-bold text-[#111] leading-[0.9] tracking-tight mb-8">
          Money<br/>Flows Here.
        </h1>
        <div className="w-12 h-[2px] bg-[#d4d4d4] mb-10" />
        <div className="mb-14">
          <p className="text-[26px] md:text-[32px] text-[#444748] leading-tight">
            사람들의 돈은
          </p>
          <p className="text-[26px] md:text-[32px] font-bold text-[#111] leading-tight">
            여기로 흐른다.
          </p>
        </div>
        
        <div className="flex flex-wrap gap-3">
          {categories.map((cat) => (
            <div key={cat.label} className="flex items-center gap-2 bg-[#111] text-white rounded-full px-5 py-2.5">
              <span className="opacity-70">{cat.icon}</span>
              <span className="text-[13px] font-bold tracking-tight">{cat.label}</span>
            </div>
          ))}
        </div>
      </div>

      {/* Right Section (60%) */}
      <div className="w-[60%] flex flex-col justify-center">
        {/* Top: Donut Chart + Legend */}
        <div className="flex items-center gap-12 mb-16">
          {/* Donut Chart */}
          <div className="relative w-[300px] h-[300px] flex items-center justify-center shrink-0">
            <svg viewBox="0 0 200 200" className="w-full h-full -rotate-90 drop-shadow-sm">
              {/* Red Segment (66.7%) - Starts at -90deg */}
              <circle
                cx="100" cy="100" r="80"
                fill="none" stroke="#f05252"
                strokeWidth="40"
                strokeDasharray={`${redDash} ${c}`}
              />
              {/* Blue Segment (23.3%) - Offset by Red */}
              <circle
                cx="100" cy="100" r="80"
                fill="none" stroke="#3f83f8"
                strokeWidth="40"
                strokeDasharray={`${blueDash} ${c}`}
                strokeDashoffset={-redDash}
              />
              {/* Light Red Segment (10%) - Offset by Red + Blue */}
              <circle
                cx="100" cy="100" r="80"
                fill="none" stroke="#ff7675"
                strokeWidth="40"
                strokeDasharray={`${lightRedDash} ${c}`}
                strokeDashoffset={-(redDash + blueDash)}
              />
            </svg>
            
            {/* Labels on Chart */}
            <div className="absolute inset-0 pointer-events-none font-['Manrope']">
              {/* Red Label */}
              <div className="absolute top-[52%] left-[15%] text-white text-center leading-none">
                <div className="text-[18px] font-bold">66.7%</div>
                <div className="text-[10px] opacity-80 mt-1">2,000,000 KRW</div>
              </div>
              {/* Blue Label */}
              <div className="absolute top-[25%] left-[62%] text-white text-center leading-none">
                <div className="text-[18px] font-bold">23.3%</div>
                <div className="text-[10px] opacity-80 mt-1">700,000 KRW</div>
              </div>
              {/* Light Red Label */}
              <div className="absolute top-[65%] left-[65%] text-white text-center leading-none">
                <div className="text-[18px] font-bold">10.0%</div>
                <div className="text-[10px] opacity-80 mt-1">300,000 KRW</div>
              </div>
            </div>

            {/* Center of Donut */}
            <div className="absolute flex flex-col items-center justify-center text-center bg-white rounded-full w-[120px] h-[120px]">
              <div className="text-[18px] font-bold text-[#111] tracking-tight leading-none mb-1">3,000,000</div>
              <div className="text-[11px] font-bold text-[#111]/50 uppercase tracking-widest">KRW / month</div>
            </div>
          </div>

          {/* Legend */}
          <div className="flex flex-col gap-8">
            <div className="flex items-start gap-4">
              <div className="w-3 h-3 rounded-full bg-[#3f83f8] mt-1.5 shrink-0" />
              <div>
                <div className="text-[16px] font-bold text-[#111]">Life Money</div>
                <div className="text-[13px] font-bold text-[#111]/80 mt-0.5">700,000 KRW (23.3%)</div>
                <div className="text-[12px] text-[#444748] mt-1 break-keep">취미, 관심사, 커뮤니티</div>
              </div>
            </div>
            <div className="flex items-start gap-4">
              <div className="w-3 h-3 rounded-full bg-[#ff7675] mt-1.5 shrink-0" />
              <div>
                <div className="text-[16px] font-bold text-[#111]">Optional Spend</div>
                <div className="text-[13px] font-bold text-[#111]/80 mt-0.5">300,000 KRW (10.0%)</div>
                <div className="text-[12px] text-[#444748] mt-1 break-keep">저축, 투자, 여가 예비</div>
              </div>
            </div>
            <div className="flex items-start gap-4">
              <div className="w-3 h-3 rounded-full bg-[#f05252] mt-1.5 shrink-0" />
              <div>
                <div className="text-[16px] font-bold text-[#111]">Dead Spend</div>
                <div className="text-[13px] font-bold text-[#111]/80 mt-0.5">2,000,000 KRW (66.7%)</div>
                <div className="text-[12px] text-[#444748] mt-1 break-keep">통신비, 주거비, 식비, 교통비, 보험료, 구독료 등</div>
              </div>
            </div>
          </div>
        </div>

        {/* Bottom: Quote + Meta */}
        <div className="flex gap-10 max-w-[700px] border-t border-[#d4d4d4]/30 pt-8">
          <div className="flex-1 relative pl-8">
            <span className="absolute top-0 left-0 text-[60px] font-serif text-[#d4d4d4] leading-none">“</span>
            <p className="text-[16px] md:text-[18px] font-medium text-[#111]/80 leading-relaxed break-keep mt-2">
              취미가 '라이프스타일 그 자체'인 중산층 상층 매니아들에게는 <strong className="text-[#111] font-bold">20~30%가 매우 표준적이고 합리적인 지출 범위</strong>라고 볼 수 있습니다.
            </p>
            <span className="absolute bottom-[-20px] right-0 text-[60px] font-serif text-[#d4d4d4] leading-none rotate-180">“</span>
          </div>
          <div className="w-[180px] text-[11px] text-[#444748] leading-relaxed border-l border-[#d4d4d4]/30 pl-6">
            <p className="font-bold text-[#111]">통계청</p>
            <p>최근 소비 트렌드 조사<br/>(2025-2026)</p>
            <p className="mt-2">전문 취미 가구의 소비 구조<br/>(Self-Actualization Spending)</p>
          </div>
        </div>
      </div>
    </div>
  );
};

